{
  "$schema": "https://v2-9-6.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": ["**/*.ts", "**/tsconfig.json", "**/tsdown.config.ts", "tsconfig.base.json"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": ["**/*.ts", "**/*.tsx", "**/oxlintrc.json"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^test"],
      "inputs": ["**/*.ts", "**/*.tsx"],
      "outputs": []
    },
    "fmt": {
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["**/*.json", "**/*.md", "**/*.ts", "**/*.tsx"]
    }
  }
}
