{
  "$schema": "https://v2-9-6.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": [
        "**/*.ts",
        "**/*.tsrx",
        "**/tsconfig.json",
        "**/tsdown.config.ts",
        "tsconfig.base.json"
      ],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": ["**/*.ts", "**/*.tsrx", "**/oxlintrc.json"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^test"],
      "inputs": ["**/*.ts", "**/*.tsrx"],
      "outputs": []
    },
    "fmt": {
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["**/*.json", "**/*.md", "**/*.ts", "**/*.tsrx"]
    }
  }
}
