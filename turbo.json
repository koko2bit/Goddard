{
  "$schema": "https://v2-9-6.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "panda:codegen": {
      "inputs": ["panda.config.ts", "src/panda-css/global.css.ts", "package.json"],
      "outputs": ["styled-system/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": [
        "**/*.ts",
        "**/*.tsrx",
        "**/*.js",
        "**/*.jsx",
        "**/*.mjs",
        "**/*.cjs",
        "**/*.json",
        "**/tsconfig.json",
        "**/tsdown.config.ts",
        "tsconfig.base.json"
      ],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": [
        "**/*.ts",
        "**/*.tsrx",
        "**/*.js",
        "**/*.jsx",
        "**/*.mjs",
        "**/*.cjs",
        "**/oxlintrc.json"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^test"],
      "inputs": [
        "**/*.ts",
        "**/*.tsrx",
        "**/*.js",
        "**/*.jsx",
        "**/*.mjs",
        "**/*.cjs",
        "**/*.json"
      ],
      "outputs": []
    },
    "fmt": {
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["**/*.json", "**/*.md", "**/*.ts", "**/*.tsrx"]
    }
  }
}
