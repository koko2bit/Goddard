+  borderRadius: "26px",
+  border: "1px solid",
+  borderColor: "border",
+  background: `linear-gradient(180deg, ${token.var("colors.panel")} 0%, ${token.var("colors.background")} 100%)`,
+  boxShadow: "0 22px 56px rgba(118, 133, 150, 0.12)",
+})
+
+const debugEyebrowClass = css({
+  display: "inline-flex",
+  alignItems: "center",
+  width: "fit-content",
+  padding: "7px 11px",
+  borderRadius: "999px",
+  backgroundColor: "surface",
+  color: "accentStrong",
+  fontSize: "0.72rem",
