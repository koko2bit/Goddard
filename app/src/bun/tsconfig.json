{
  "compilerOptions": {
    "types": ["bun"],
    "rootDir": "../..",
    "paths": {
      "~/*": ["../*"]
    },

    /* Inherited from tsconfig.base.json */
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "customConditions": ["source", "import", "default"]
  },
  "include": [".", "../shared", "../types.d.ts"]
}
