{
  "name": "@goddard-ai/app",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0",
  "type": "module",
  "scripts": {
    "predev": "bun install",
    "dev": "picorun 'bun run vite:dev' 'bun run electrobun:watch:hmr' --names=vite,electrobun",
    "prebuild": "bun run panda:sync",
    "build": "vite build && electrobun build",
    "icons:generate": "bun run ./scripts/generate-iconset.mjs",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "test": "vitest run -c ../vitest.config.ts",
    "pretypecheck": "bun run panda:sync",
    "typecheck": "picorun 'tsgo -p src/bun --noEmit' 'tsgo --noEmit' --names='tsgo:src/bun',tsgo",
    "electrobun:watch": "electrobun dev --watch",
    "electrobun:watch:hmr": "sh -c 'until curl -fsSI http://127.0.0.1:5173 >/dev/null; do sleep 0.2; done; bun run electrobun:watch'",
    "panda:sync": "panda codegen && panda cssgen",
    "vite:dev": "vite"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.3",
    "@goddard-ai/daemon-client": "workspace:^",
    "@goddard-ai/ipc": "workspace:^",
    "@goddard-ai/schema": "workspace:^",
    "@goddard-ai/sdk": "workspace:^",
    "@goddard-ai/styled-system": "workspace:^",
    "@preact/signals": "^2.9.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/preact-query": "^5.95.2",
    "@xterm/headless": "^6.0.0",
    "bun-pty": "^0.4.8",
    "electrobun": "^1.16.0",
    "lucide-react": "^1.7.0",
    "preact": "11.0.0-beta.1",
    "preact-in-motion": "^0.2.9",
    "preact-sigma": "^2.0.1",
    "radashi": "^12.7.2",
    "react-virtuoso": "^4.18.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@pandacss/dev": "^1.9.1",
    "@preact/preset-vite": "^2.10.5",
    "@spiriit/vite-plugin-svg-spritemap": "7.0.0",
    "@types/bun": "^1.3.11",
    "@types/react": "file:overrides/react",
    "@types/react-dom": "file:overrides/react",
    "chokidar": "^5.0.0",
    "picorun": "^0.1.5",
    "react": "file:overrides/react",
    "react-dom": "file:overrides/react",
    "vite": "^8.0.3"
  }
}
