{
  "name": "@goddard-ai/app",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0",
  "type": "module",
  "scripts": {
    "prepare": "pnpm run panda:sync",
    "predev": "pnpm run panda:sync",
    "dev": "picorun 'pnpm panda:watch' 'pnpm electrobun:watch' --names=panda,electrobun",
    "prebuild": "pnpm run panda:sync",
    "build": "electrobun build",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "test": "vitest run -c ../vitest.config.ts",
    "pretypecheck": "pnpm run panda:sync",
    "typecheck": "tsgo -p . --noEmit",
    "electrobun:watch": "electrobun dev --watch",
    "panda:sync": "panda codegen && panda cssgen",
    "panda:watch": "panda --watch"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.3",
    "@goddard-ai/daemon-client": "workspace:^",
    "@goddard-ai/ipc": "workspace:^",
    "@goddard-ai/schema": "workspace:^",
    "@goddard-ai/sdk": "workspace:^",
    "@preact/signals": "^2.8.1",
    "@tanstack/preact-query": "^5.95.2",
    "electrobun": "^1.16.0",
    "preact": "11.0.0-beta.1",
    "preact-in-motion": "^0.2.9",
    "preact-sigma": "^2.0.0",
    "radashi": "^12.7.2",
    "react-virtuoso": "^4.18.3"
  },
  "devDependencies": {
    "@pandacss/dev": "^1.9.1",
    "@types/bun": "^1.3.11",
    "picorun": "^0.1.5"
  }
}
