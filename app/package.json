{
  "name": "@goddard-ai/app",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0",
  "type": "module",
  "scripts": {
    "prepare": "panda codegen && bun run ./scripts/generate-svg-icon-data.ts",
    "dev": "bun install --frozen-lockfile && bun run ./scripts/dev.ts",
    "build": "panda codegen && vite build && electrobun build",
    "build:canary": "bun run build --env=canary",
    "build:stable": "bun run build --env=stable",
    "icons:generate": "bun run ./scripts/generate-iconset.ts",
    "lint": "oxlint",
    "fmt": "prettier -w .",
    "test": "bun test --dots",
    "typecheck": "panda codegen && tsrx-tsc --noEmit"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "catalog:",
    "@ark-ui/react": "^5.36.2",
    "@chenglou/pretext": "^0.0.4",
    "@goddard-ai/daemon-client": "workspace:^",
    "@goddard-ai/ipc": "workspace:^",
    "@goddard-ai/paths": "workspace:^",
    "@goddard-ai/schema": "workspace:^",
    "@goddard-ai/sdk": "workspace:^",
    "@goddard-ai/styled-system": "workspace:^",
    "@lexical/react": "^0.42.0",
    "@preact/signals": "^2.9.0",
    "@tsrx/preact": "^0.0.17",
    "@xterm/headless": "^6.0.0",
    "ark-cmdk": "^0.1.1",
    "bun-pty": "^0.4.8",
    "comark": "0.2.1",
    "culori": "^4.0.2",
    "electrobun": "^1.16.0",
    "fuzzysort2": "^0.1.1",
    "hash-sum": "^2.0.0",
    "immer": "^11.1.4",
    "lexical": "^0.42.0",
    "lucide-react": "^1.11.0",
    "powerkeys": "^0.1.2",
    "preact": "11.0.0-beta.1",
    "preact-comark": "0.2.4",
    "preact-in-motion": "^0.2.9",
    "preact-sigma": "6.1.0",
    "radashi": "catalog:",
    "react-virtuoso": "^4.18.6",
    "sharp": "^0.34.5",
    "shiki": "4.0.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@pandacss/dev": "catalog:",
    "@preact/preset-vite": "^2.10.5",
    "@spiriit/vite-plugin-svg-spritemap": "7.0.0",
    "@tsrx/bun-plugin-preact": "^0.0.16",
    "@tsrx/vite-plugin-preact": "^0.0.17",
    "@types/culori": "^4.0.1",
    "chokidar": "^5.0.0",
    "postcss": "^8.5.10",
    "react": "npm:@preact/compat",
    "react-dom": "npm:@preact/compat",
    "vite": "^8.0.10"
  },
  "overrides": {}
}
