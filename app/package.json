{
  "name": "@goddard-ai/app",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0",
  "type": "module",
  "scripts": {
    "prepare": "bun run ./scripts/generate-svg-icon-data.ts",
    "dev": "bun install --frozen-lockfile && bun run ./scripts/dev.ts",
    "build": "panda codegen && vite build && electrobun build",
    "build:canary": "bun run build --env=canary",
    "build:stable": "bun run build --env=stable",
    "icons:generate": "bun run ./scripts/generate-iconset.ts",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "test": "bun test --dots",
    "typecheck": "panda codegen && tsgo --noEmit"
  },
  "dependencies": {
    "@ark-ui/react": "^5.36.0",
    "@chenglou/pretext": "^0.0.3",
    "@goddard-ai/daemon-client": "workspace:^",
    "@goddard-ai/ipc": "workspace:^",
    "@goddard-ai/paths": "workspace:^",
    "@goddard-ai/schema": "workspace:^",
    "@goddard-ai/sdk": "workspace:^",
    "@goddard-ai/styled-system": "workspace:^",
    "@lexical/react": "^0.30.0",
    "@preact/signals": "^2.9.0",
    "@xterm/headless": "^6.0.0",
    "ark-cmdk": "^0.1.1",
    "bun-pty": "^0.4.8",
    "comark": "0.2.1",
    "culori": "^4.0.2",
    "electrobun": "^1.16.0",
    "hash-sum": "^2.0.0",
    "lexical": "^0.30.0",
    "lucide-react": "^1.7.0",
    "powerkeys": "^0.1.0",
    "preact": "11.0.0-beta.1",
    "preact-comark": "0.2.4",
    "preact-in-motion": "^0.2.9",
    "preact-sigma": "^2.3.0",
    "radashi": "^12.7.2",
    "react-virtuoso": "^4.18.3",
    "sharp": "^0.34.5",
    "shiki": "4.0.2"
  },
  "devDependencies": {
    "@pandacss/dev": "^1.9.1",
    "@preact/preset-vite": "^2.10.5",
    "@spiriit/vite-plugin-svg-spritemap": "7.0.0",
    "@types/culori": "^4.0.1",
    "chokidar": "^5.0.0",
    "postcss": "^8.5.8",
    "procband": "^0.3.0",
    "react": "npm:@preact/compat",
    "react-dom": "npm:@preact/compat",
    "vite": "^8.0.3"
  }
}
