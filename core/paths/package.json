{
  "name": "@goddard-ai/paths",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": {
        "source": "./src/index.ts",
        "default": "./dist/index.d.mts"
      },
      "import": "./dist/index.mjs"
    },
    "./node": {
      "types": {
        "source": "./src/node/index.ts",
        "default": "./dist/node/index.d.mts"
      },
      "import": "./dist/node/index.mjs"
    },
    "./tauri": {
      "types": {
        "source": "./src/tauri/index.ts",
        "default": "./dist/tauri/index.d.mts"
      },
      "import": "./dist/tauri/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "typecheck": "tsdown --no-minify --clean --unused --log-level error",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@tauri-apps/api": "^2.10.1"
  },
  "peerDependenciesMeta": {
    "@tauri-apps/api": {
      "optional": true
    }
  }
}
