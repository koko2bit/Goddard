{
  "name": "@goddard-ai/daemon-client",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": {
        "source": "./src/index.ts",
        "default": "./dist/index.d.mts"
      },
      "import": {
        "source": "./src/index.ts",
        "default": "./dist/index.mjs"
      }
    }
  },
