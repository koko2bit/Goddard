{
  "name": "@goddard-ai/daemon-client",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": {
        "source": "./src/index.ts",
        "default": "./dist/index.d.mts"
      },
      "bun": "./src/index.ts",
      "import": "./dist/index.mjs"
    },
    "./node": {
      "types": {
        "source": "./src/node/index.ts",
        "default": "./dist/node/index.d.mts"
      },
      "bun": "./src/node/index.ts",
      "import": "./dist/node/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown --unused",
    "lint": "oxlint",
    "fmt": "prettier -w .",
    "typecheck": "tsgo --noEmit && tsgo -p src/node --noEmit && tsgo -p test --noEmit",
    "test": "bun test --dots"
  },
  "dependencies": {
    "@goddard-ai/ipc": "workspace:^",
    "@goddard-ai/paths": "workspace:^",
    "@goddard-ai/schema": "workspace:^"
  }
}
