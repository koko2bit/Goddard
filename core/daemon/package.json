{
  "name": "@goddard-ai/daemon",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0",
  "bin": {
    "goddard-daemon": "./dist/main.mjs"
  },
  "type": "module",
  "exports": {
    "./ipc": {
      "types": {
        "source": "./src/ipc.ts",
        "default": "./dist/ipc.d.mts"
      },
      "bun": "./src/ipc.ts",
      "import": "./dist/ipc.mjs"
    },
    "./workforce": {
      "types": {
        "source": "./src/workforce/index.ts",
        "default": "./dist/workforce/index.d.mts"
      },
      "bun": "./src/workforce/index.ts",
      "import": "./dist/workforce/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown --unused",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "typecheck": "tsgo --noEmit",
    "test": "bun test --dots"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.15.0",
    "@alloc/tree-kill": "^1.3.0",
    "@b9g/async-context": "^0.2.1",
    "@goddard-ai/config": "workspace:^",
    "@goddard-ai/daemon-client": "workspace:^",
    "@goddard-ai/ipc": "workspace:^",
    "@goddard-ai/paths": "workspace:^",
    "@goddard-ai/schema": "workspace:^",
    "@goddard-ai/worktree-plugin": "workspace:^",
    "cmd-ts": "^0.15.0",
    "hash-sum": "^2.0.0",
    "kindstore": "^0.4.1",
    "kleur": "^4.1.5",
    "node-stream-zip": "^1.15.0",
    "radashi": "^12.7.2",
    "rouzer": "^2.0.0",
    "tar-fs": "^3.1.2",
    "unbzip2-stream": "^1.4.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@goddard-ai/backend": "workspace:^",
    "@types/hash-sum": "^1.0.2",
    "@types/tar-fs": "^2.0.4",
    "@types/unbzip2-stream": "^1.4.3"
  }
}
