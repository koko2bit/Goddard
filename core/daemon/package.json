{
  "name": "@goddard-ai/daemon",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0",
  "bin": {
    "goddard-daemon": "./dist/main.mjs"
  },
  "type": "module",
  "exports": {
    "./ipc": {
      "types": {
        "source": "./src/ipc.ts",
        "default": "./dist/ipc.d.mts"
      },
      "import": "./dist/ipc.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "typecheck": "tsdown --no-minify --clean --unused --log-level error",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.15.0",
    "@goddard-ai/backend-client": "workspace:^",
    "@goddard-ai/config": "workspace:^",
    "@goddard-ai/daemon-client": "workspace:^",
    "@goddard-ai/ipc": "workspace:^",
    "@goddard-ai/schema": "workspace:^",
    "@goddard-ai/storage": "workspace:^",
    "@goddard-ai/tree-kill": "workspace:^",
    "@goddard-ai/worktree": "workspace:^",
    "cmd-ts": "^0.15.0",
    "cron-parser": "^5.5.0",
    "kleur": "^4.1.5",
    "node-stream-zip": "^1.15.0",
    "radashi": "^12.7.2",
    "tar-fs": "^3.1.2",
    "unbzip2-stream": "^1.4.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/tar-fs": "^2.0.4",
    "@types/unbzip2-stream": "^1.4.3"
  }
}
