{
  "name": "@goddard-ai/ipc",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "source": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts",
      "source": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "tree-run build && tsdown",
    "build:types": "tsdown --no-minify --clean --unused",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5"
  }
}
