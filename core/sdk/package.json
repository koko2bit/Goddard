{
  "name": "@goddard-ai/sdk",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": {
        "source": "./src/index.ts",
        "default": "./dist/index.d.mts"
      },
      "import": "./dist/index.mjs"
    },
    "./daemon": {
      "types": {
        "source": "./src/daemon/index.ts",
        "default": "./dist/daemon/index.d.mts"
      },
      "import": "./dist/daemon/index.mjs"
    },
    "./node": {
      "types": {
        "source": "./src/node/index.ts",
        "default": "./dist/node/index.d.mts"
      },
      "import": "./dist/node/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "typecheck": "tsdown --no-minify --clean --unused --log-level error",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.15.0",
    "@goddard-ai/daemon-client": "workspace:^",
    "@goddard-ai/schema": "workspace:^"
  },
  "devDependencies": {
    "@goddard-ai/daemon": "workspace:^"
  }
}
