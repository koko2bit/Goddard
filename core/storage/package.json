{
  "name": "@goddard-ai/storage",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "source": "./src/index.ts"
    },
    "./session-permissions": {
      "types": "./src/session-permissions.ts",
      "import": "./dist/session-permissions.js",
      "source": "./src/session-permissions.ts"
    },
    "./managed-pr-locations": {
      "types": "./src/managed-pr-locations.ts",
      "import": "./dist/managed-pr-locations.js",
      "source": "./src/managed-pr-locations.ts"
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.json --noCheck",
    "build:types": "tsgo -p tsconfig.json --noCheck",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.15.0",
    "better-sqlite3": "^12.6.2",
    "drizzle-kit": "1.0.0-beta.16-ea816b6",
    "drizzle-orm": "1.0.0-beta.16-ea816b6",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@goddard-ai/schema": "workspace:^",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.5"
  }
}
