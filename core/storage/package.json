{
  "name": "@goddard-ai/storage",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": {
        "source": "./src/index.ts",
        "default": "./dist/index.d.mts"
      },
      "import": "./dist/index.mjs"
    },
    "./session-permissions": {
      "types": {
        "source": "./src/session-permissions.ts",
        "default": "./dist/session-permissions.d.mts"
      },
      "import": "./dist/session-permissions.mjs"
    },
    "./managed-pr-locations": {
      "types": {
        "source": "./src/managed-pr-locations.ts",
        "default": "./dist/managed-pr-locations.d.mts"
      },
      "import": "./dist/managed-pr-locations.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "typecheck": "tsdown --no-minify --clean --unused --log-level error",
    "test": "vitest run --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.15.0",
    "@goddard-ai/schema": "workspace:^",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "1.0.0-beta.16-ea816b6",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.5",
    "drizzle-kit": "1.0.0-beta.16-ea816b6"
  }
}
