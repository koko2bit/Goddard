{
  "name": "@goddard-ai/schema",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    "./*": {
      "types": "./dist/*.d.mts",
      "import": "./dist/*.mjs",
      "source": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "typecheck": "tsdown --no-minify --clean --unused --log-level error",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.15.0",
    "@goddard-ai/ipc": "workspace:^",
    "rouzer": "^2.0.0",
    "zod": "^4.3.6"
  }
}
