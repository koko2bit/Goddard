{
  "name": "@goddard-ai/schema",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    "./*": {
      "types": {
        "source": "./src/*.ts",
        "default": "./dist/*.d.mts"
      },
      "bun": "./src/*.ts",
      "import": "./dist/*.mjs"
    },
    "./json/*": "./json/*"
  },
  "scripts": {
    "build": "tsdown --unused && bun run generate-schemas",
    "generate-schemas": "node scripts/generate-json-schemas.ts && oxfmt json/",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "typecheck": "tsgo --noEmit",
    "test": "bun test --dots"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.15.0",
    "@goddard-ai/ipc": "workspace:^",
    "rouzer": "^2.0.0",
    "zod": "^4.3.6"
  }
}
