{
  "name": "@goddard-ai/backend",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0",
  "bin": {
    "goddard-backend": "./dist/server.mjs"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": {
        "source": "./src/index.ts",
        "default": "./dist/index.d.mts"
      },
      "bun": "./src/index.ts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "start": "node dist/server.mjs",
    "build": "tsdown --unused",
    "dev": "wrangler dev",
    "deploy": "alchemy deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "typecheck": "tsgo --noEmit",
    "test": "bun test --dots"
  },
  "dependencies": {
    "@goddard-ai/schema": "workspace:^",
    "@hattip/adapter-cloudflare-workers": "^0.0.49",
    "@hattip/adapter-node": "^0.0.49",
    "@libsql/client": "^0.17.0",
    "drizzle-orm": "1.0.0-beta.18-7eb39f0",
    "octokit": "^5.0.5",
    "rouzer": "^2.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260307.1",
    "alchemy": "^0.87.0",
    "wrangler": "^4.71.0"
  }
}
