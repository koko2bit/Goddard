{
  "name": "pi-loop",
  "version": "1.0.0",
  "description": "Endless Rate-Limited Agentic Loop for pi-coding-agent",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./strategies": {
      "types": "./dist/strategies/index.d.ts",
      "import": "./dist/strategies/index.mjs",
      "require": "./dist/strategies/index.js"
    }
  },
  "bin": {
    "pi-loop": "./dist/cli.js"
  },
  "files": [
    "dist",
    "config.example.ts"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts src/strategies/index.ts --format esm,cjs --dts --sourcemap --target node20"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "typescript": ">=5.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "commander": "^12.1.0",
    "cron-parser": "^4.9.0",
    "exit-hook": "^5.1.0",
    "jiti": "^2.6.1",
    "p-limit": "^6.2.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.55.3",
    "@types/node": "^22.13.4",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aleclarson/pi-loop.git"
  },
  "keywords": [
    "pi-coding-agent",
    "agentic-loop",
    "automation",
    "typescript",
    "daemon"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/aleclarson/pi-loop/issues"
  },
  "homepage": "https://github.com/aleclarson/pi-loop#readme"
}
