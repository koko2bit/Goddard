#!/usr/bin/env sh

remote_name=$1

if [ "$remote_name" != "origin" ]; then
  exit 0
fi

pushed_sha=

while read local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "refs/heads/main" ] && [ "$local_ref" != "(delete)" ]; then
    pushed_sha=$local_sha
    break
  fi
done

if [ -z "$pushed_sha" ]; then
  exit 0
fi

if ! git rev-parse --verify --quiet origin/main >/dev/null; then
  bun install && bun check || exit 1
  exit 0
fi

branch_point=$(git merge-base "$pushed_sha" origin/main)

if [ -z "$branch_point" ]; then
  bun install && bun check || exit 1
  exit 0
fi

changed_files=$(git diff --name-only "$branch_point".."$pushed_sha")

# Run the full repo check only when the branch changed files that affect it.
if printf '%s\n' "$changed_files" | grep -Eq \
  '(^|/)src/.*\.(ts|tsx|mts|cts|js|jsx|mjs|cjs)$|(^|/).*\.test\.(ts|tsx|mts|cts|js|jsx|mjs|cjs)$|(^|/)tsconfig(\.[^/]+)?\.json$|(^|/)package\.json$|(^|/)tsdown\.config\.ts$'
then
  bun install && bun check || exit 1
fi
