{
  "name": "goddard",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "app",
    "app/styled-system",
    "core/*",
    "core/daemon/client",
    "workforce"
  ],
  "catalog": {
    "@agentclientprotocol/sdk": "^0.19.2",
    "@clack/prompts": "^1.3.0",
    "@pandacss/dev": "^1.10.0",
    "ai-sdk-json-schema": "^0.3.0",
    "cmd-ts": "^0.15.0",
    "radashi": "^12.7.2",
    "rouzer": "^2.0.0",
    "zod": "^4.3.6"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "precommit:staged-fix": "bun run ./scripts/pre-commit-staged-fix.mjs",
    "postcommit:restore-stash": "bun run ./scripts/post-commit-restore-stash.mjs",
    "prepush:check": "bun run ./scripts/pre-push.ts",
    "dev": "bun run ./scripts/dev.ts",
    "build": "turbo run build",
    "fmt": "turbo run fmt",
    "typecheck": "turbo run typecheck --output-logs=errors-only",
    "lint": "turbo run lint --output-logs=errors-only",
    "test": "turbo run test --output-logs=errors-only",
    "smoke:review-sync": "bun run --cwd core/review-sync smoke",
    "smoke:sprint-branch": "bun run ./core/sprint-branch/scripts/smoke.ts",
    "smoke:workforce": "node ./scripts/smoke-workforce.mjs",
    "acp": "bun run ./scripts/acp-session.ts",
    "goddard:daemon": "NODE_ENV=development bun run ./core/daemon/src/main.ts",
    "goddard:workforce": "NODE_ENV=development bun run ./workforce/src/main.ts",
    "check": "bun run typecheck && bun run lint && bun run test"
  },
  "devDependencies": {
    "@clack/prompts": "catalog:",
    "@goddard-ai/review-sync": "workspace:*",
    "@goddard-ai/sprint-branch": "workspace:*",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@prettier/plugin-oxc": "^0.1.4",
    "@tsrx/eslint-plugin": "^0.3.42",
    "@tsrx/prettier-plugin": "^0.3.42",
    "@tsrx/typescript-plugin": "^0.3.42",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260401.1",
    "cmd-ts": "catalog:",
    "drizzle-kit": "1.0.0-beta.18-7eb39f0",
    "globrex": "^0.1.2",
    "husky": "^9.1.7",
    "oxlint": "^1.61.0",
    "prettier": "^3.8.3",
    "procband": "^0.3.2",
    "radashi": "catalog:",
    "tsdown": "^0.21.10",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "unplugin-raw": "^0.6.4",
    "unplugin-unused": "^0.5.7"
  },
  "packageManager": "bun@1.3.11",
  "patchedDependencies": {
    "@tsrx/react@0.0.7": "patches/@tsrx%2Freact@0.0.7.patch",
    "@zag-js/popover@1.39.1": "patches/@zag-js%2Fpopover@1.39.1.patch",
    "@ark-ui/react@5.36.0": "patches/@ark-ui%2Freact@5.36.0.patch"
  }
}
