{
  "name": "goddard",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "workspaces": [
    "backend",
    "cmd",
    "daemon",
    "github-app",
    "sdk",
    "core/schema",
    "core/storage"
  ],
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260301.1",
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "unplugin-raw": "^0.6.4",
    "vitest": "^1.0.0"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "pnpm -r run lint",
