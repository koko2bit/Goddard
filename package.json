{
  "name": "goddard",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "app",
    "app/styled-system",
    "core/*",
    "core/daemon/client",
    "workforce"
  ],
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "precommit:staged-fix": "bun run ./scripts/pre-commit-staged-fix.mjs",
    "postcommit:restore-stash": "bun run ./scripts/post-commit-restore-stash.mjs",
    "prepush:check": "bun run ./scripts/pre-push.ts",
    "build": "turbo run build",
    "fmt": "turbo run fmt",
    "typecheck": "turbo run typecheck --output-logs=errors-only",
    "lint": "turbo run lint --output-logs=errors-only",
    "test": "turbo run test --output-logs=errors-only",
    "smoke:workforce": "node ./scripts/smoke-workforce.mjs",
    "acp": "bun run ./scripts/acp-session.ts",
    "goddard:daemon": "bun run ./core/daemon/src/main.ts",
    "goddard:workforce": "bun run ./workforce/src/main.ts",
    "check": "bun run typecheck && bun run lint && bun run test"
  },
  "dependencies": {
    "kindstore": "0.4.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260307.1",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.3.5",
    "@typescript/native-preview": "7.0.0-dev.20260317.1",
    "cmd-ts": "^0.15.0",
    "drizzle-kit": "1.0.0-beta.18-7eb39f0",
    "globrex": "^0.1.2",
    "husky": "^9.1.7",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "radashi": "^12.7.2",
    "tsdown": "^0.21.0",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "unplugin-raw": "^0.6.4",
    "unplugin-unused": "^0.5.7"
  },
  "packageManager": "bun@1.3.11"
}
