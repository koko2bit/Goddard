{
  "name": "goddard",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "core/backend",
    "daemon",
    "daemon/*",
    "core/sdk",
    "core/schema",
    "core/storage",
    "core/config",
    "core/tauri-plugin-ipc",
    "core/ipc",
    "core/tree-build"
  ],
  "scripts": {
    "fmt": "pnpm -r run fmt",
    "fmt:diff": "oxfmt --no-error-on-unmatched-pattern $(git diff --name-only origin/main)",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run test"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260307.1",
    "@goddard/tree-build": "workspace:*",
    "@types/node": "^25.3.5",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "radashi": "^12.7.2",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3",
    "unplugin-raw": "^0.6.4",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "koffi",
      "protobufjs",
      "sharp",
      "workerd"
    ]
  }
}
